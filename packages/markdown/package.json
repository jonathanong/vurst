{
  "name": "@jongleberry/vurst-markdown",
  "version": "0.0.2",
  "description": "Rust + N-API: Markdown chunking and rendering.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">= 18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanong/vurst.git"
  },
  "keywords": [
    "rust",
    "napi",
    "markdown",
    "chunking",
    "rag",
    "rendering"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "*.node"
  ],
  "napi": {
    "binaryName": "vurst-markdown",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test __test__/*.test.mjs",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^24"
  }
}
